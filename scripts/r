GPU_ID=$1
CONTAINER_NAME="mh_openocr_gch_gpu${GPU_ID}"

docker run -it --shm-size=64gb \
    -v /data2/hoonisone2/projects/openocr_gch:/home \
    -w /home \
    --gpus "device=${GPU_ID}" \
    -m 128g \
    --memory-swap 128g \
    --cpus=30 \
    --cpu-shares=256 \
    --name "${CONTAINER_NAME}" \
    hoonisone/openocr:0.2.0___2.6.0-cuda12.6-cudnn9-devel \
    /bin/bash
